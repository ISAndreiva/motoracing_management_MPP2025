<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane prefHeight="437.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="internal.andreiva.concursmotociclism.gui.GuiAdminController">
   <children>
      <TableView fx:id="racerTable" layoutX="12.0" layoutY="50.0" prefHeight="338.0" prefWidth="575.0" visible="false">
        <columns>
          <TableColumn fx:id="racerTableName" prefWidth="288.0" text="Nume" />
          <TableColumn fx:id="racerTableClass" minWidth="0.0" prefWidth="285.0" text="Clasa/e" />
        </columns>
      </TableView>
      <TextField fx:id="teamSearchField" layoutX="220.0" layoutY="14.0" onAction="#teamSearchFieldUpdated" promptText="Introdu o echipa..." />
      <Button fx:id="logoutButton" layoutX="526.0" layoutY="397.0" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
      <Button layoutX="12.0" layoutY="397.0" mnemonicParsing="false" onAction="#handleAddRacer" text="Inscrie Participant" />
      <TabPane fx:id="racesTabPane" layoutX="14.0" layoutY="46.0" prefHeight="346.0" prefWidth="575.0" side="BOTTOM" tabClosingPolicy="UNAVAILABLE" />
   </children>
</AnchorPane>
